{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus-solutions/refs/heads/main/json-structure/branded-fares-upsell-original-flight-end-point-structure.json",
  "name": "OriginalFlightEndPoint",
  "description": "departure or arrival information",
