  "name": "BaggageAllowance",
  "description": "baggageAllowance",
  "type": "object",
  "properties": {
    "excessRate": {
      "$ref": "#/definitions/ElementaryPrice"
    },
    "quantity": {
      "type": "int32",
      "description": "Total number of units",
      "example": 1
    },
    "weight": {
      "type": "int32",
