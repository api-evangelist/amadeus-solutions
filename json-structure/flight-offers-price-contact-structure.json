{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amadeus-solutions/refs/heads/main/json-structure/flight-offers-price-contact-structure.json",
  "name": "Contact",
  "description": "contact information",
  "allOf": [
    {
      "$ref": "#/definitions/ContactDictionary"
    },
    {
      "type": "object",
      "properties": {
        "phones": {
          "description": "Phone numbers",
          "type": "array",
          "maxItems": 3,
          "items": {
            "$ref": "#/definitions/Phone"
          }
        },
        "companyName": {
          "description": "Name of the company",
          "type": "string",
          "example": "AMADEUS"
        },
        "emailAddress": {
          "type": "string",
          "description": "Email address (e.g. john@smith.com)",
          "example": "support@mail.com"
        }
      }
    }
  ]
}